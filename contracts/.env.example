# Testnet deployment — copy to .env and fill before running:
DEPLOYER_PRIVATE_KEY=0x...
PRODUCER_ADDRESS=0x...
AUDITOR_ADDRESS=0x...

# Optional: separate keys for role-separated gas eval
# PRODUCER_PRIVATE_KEY=0x...
# AUDITOR_PRIVATE_KEY=0x...

# Optional: reuse deployed contract instead of fresh deploy in evaluate-gas
# HALALCHAIN_ADDRESS=0x...

# Ethereum Sepolia (recommended if you already have Sepolia ETH)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETHERSCAN_API_KEY=

# Base Sepolia (optional — paper L2 target)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=
